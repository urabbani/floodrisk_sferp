<?xml version="1.0" encoding="UTF-8"?>
<StyledLayerDescriptor version="1.0.0"
  xsi:schemaLocation="http://www.opengis.net/sld StyledLayerDescriptor.xsd"
  xmlns="http://www.opengis.net/sld"
  xmlns:ogc="http://www.opengis.net/ogc"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <NamedLayer>
    <Name>hydrosheds_streamnetwork</Name>
    <UserStyle>
      <Title>HydroSHEDS Stream Network</Title>
      <Abstract>Stream network with flow accumulation threshold of 500. Values below 500 are transparent. Continuous gradient coloring from light blue to navy blue based on stream size.</Abstract>

      <FeatureTypeStyle>
        <Rule>
          <Name>Stream Network Gradient</Name>
          <RasterSymbolizer>
            <Opacity>0.8</Opacity>
            <ColorMap type="ramp">
              <!-- Below threshold: Transparent -->
              <ColorMapEntry color="#000000" quantity="0" opacity="0"/>
              <ColorMapEntry color="#000000" quantity="500" opacity="0"/>

              <!-- Small streams (500-1000): Light Blue -->
              <ColorMapEntry color="#64B5F6" quantity="500" opacity="0.7"/>
              <ColorMapEntry color="#42A5F5" quantity="1000" opacity="0.75"/>

              <!-- Tributaries (1000-5000): Medium Blue -->
              <ColorMapEntry color="#1E88E5" quantity="2500" opacity="0.8"/>
              <ColorMapEntry color="#1976D2" quantity="5000" opacity="0.82"/>

              <!-- Major rivers (5000-10000): Dark Blue -->
              <ColorMapEntry color="#1565C0" quantity="7500" opacity="0.85"/>
              <ColorMapEntry color="#0D47A1" quantity="10000" opacity="0.88"/>

              <!-- Main stem (10000+): Navy -->
              <ColorMapEntry color="#0D47A1" quantity="20000" opacity="0.9"/>
              <ColorMapEntry color="#0D47A1" quantity="50000" opacity="0.92"/>
            </ColorMap>
          </RasterSymbolizer>
        </Rule>
      </FeatureTypeStyle>
    </UserStyle>
  </NamedLayer>
</StyledLayerDescriptor>
